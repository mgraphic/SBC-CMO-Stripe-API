# Port the mock API listens on
PORT=4242

# Comma-separated list of valid API keys (Bearer token values)
# Use any value here; your app must send: Authorization: Bearer <key>
STRIPE_API_KEYS=sk_test_mock

# Base URL used when generating checkout session URLs
BASE_URL=http://localhost:4242

# Absolute or relative path to the directory containing products.json / prices.json
DATA_DIR=./data
