{
    "name": "sbc-cmo-stripe-mock-api",
    "version": "1.0.0",
    "description": "A local mock Stripe API server supporting Products, Prices, and Checkout Sessions",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "clean": "rm -rf dist"
    },
    "keywords": [
        "stripe",
        "mock",
        "api",
        "typescript"
    ],
    "license": "MIT",
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "morgan": "^1.10.0",
        "stripe": "^20.4.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/morgan": "^1.9.9",
        "@types/node": "^20.14.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}
